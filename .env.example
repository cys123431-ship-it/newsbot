NEWSBOT_DATABASE_URL=sqlite:///./newsbot.db
NEWSBOT_BOOTSTRAP_ON_STARTUP=true
NEWSBOT_ENABLE_SCHEDULER=true
NEWSBOT_REQUEST_TIMEOUT_SEC=10
NEWSBOT_MAX_RETRIES=3
NEWSBOT_AUTO_DISABLE_AFTER_FAILURES=5

NEWSBOT_TELEGRAM_INPUT_ENABLED=false
NEWSBOT_TELEGRAM_API_ID=
NEWSBOT_TELEGRAM_API_HASH=
NEWSBOT_TELEGRAM_SESSION_NAME=newsbot
NEWSBOT_TELEGRAM_SESSION_STRING=

NEWSBOT_NAVER_CLIENT_ID=
NEWSBOT_NAVER_CLIENT_SECRET=

NEWSBOT_STATIC_OUTPUT_DIR=site-dist
NEWSBOT_STATIC_FETCH_CONCURRENCY=5
NEWSBOT_STATIC_MIN_ARTICLES_TO_PUBLISH=20
NEWSBOT_STATIC_MAX_ARTICLES_PER_SOURCE=18
NEWSBOT_STATIC_MAX_TOTAL_ARTICLES=140
